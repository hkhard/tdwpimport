<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnWarning="true"
         failOnRisky="true"
         beStrictAboutOutputDuringTests="false"
         cacheDirectory=".phpunit.cache">
    <!--
        beStrictAboutOutputDuringTests is OFF: the legacy .tdt parser /
        domain-mapper / formula-validator emit pre-existing diagnostic error_log()
        output during normal parsing. These tests assert on returned data, not on
        stdout. Removing that diagnostic spam from production code is tracked as a
        follow-up; flip this back to "true" once that lands.
    -->
    <testsuites>
        <testsuite name="unit">
            <directory>tests/unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">includes</directory>
            <directory suffix=".php">admin</directory>
        </include>
    </source>
</phpunit>
